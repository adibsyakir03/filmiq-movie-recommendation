# ============================================================
#  .gitignore — FilmIQ Movie Recommendation
# ============================================================

# ------------------------------------------------------------
# RAW DATA — never commit source data files
# ------------------------------------------------------------
data/raw/
data/processed/*.csv
data/processed/*.pkl
data/processed/*.npz

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ------------------------------------------------------------
# DATABASE CREDENTIALS
# ------------------------------------------------------------
.env
db_config.py
db_config.R
*.credentials

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# R
# ------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ------------------------------------------------------------
# Model files (can be large)
# ------------------------------------------------------------
*.pkl
*.joblib
*.model
models/

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*~

# ------------------------------------------------------------
# Outputs
# ------------------------------------------------------------
outputs/charts/*.png
outputs/charts/*.pdf
!outputs/charts/.gitkeep
